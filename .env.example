# hoodpad environment template — copy to .env and fill in. No secrets in this file.

# Robinhood Chain (chain ID 4663) RPC — used by fork tests, indexer, api, web
ROBINHOOD_RPC_URL=
ROBINHOOD_WS_RPC_URL=

# Off-chain stack (spec §8)
DATABASE_URL=
REDIS_URL=

# Cloudflare R2 (metadata/image storage, spec §8.3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
