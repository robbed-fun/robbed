# ROBBED_ environment template — copy to .env and fill in. No secrets in this file.

# Robinhood Chain (chain ID 4663) RPC — used by fork tests, indexer, api, web
ROBINHOOD_RPC_URL=
ROBINHOOD_WS_RPC_URL=

# Off-chain stack
DATABASE_URL=
REDIS_URL=

# Cloudflare R2 (metadata/image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── apps/web (@robbed/web) — Cloudflare Workers BUILD VARS ────────────────────
# NEXT_PUBLIC_* are inlined by Next AT BUILD TIME, so on Cloudflare Workers they
# must be set as *build variables* in the Workers-Builds environment (NOT runtime
# secrets). A missing var will not crash the build (safe placeholder), but the
# deployed app is only functional once these point at the live Komodo stack.
# Chain id (4663) is NOT here — it is a compile-time constant from @robbed/shared.
NEXT_PUBLIC_RPC_HTTP=          # chain 4663 HTTP RPC (required)
NEXT_PUBLIC_RPC_WS=            # chain 4663 WS RPC (optional)
NEXT_PUBLIC_API_BASE_URL=     # indexer/API base, e.g. https://api.robbed.example (required, no trailing slash)
NEXT_PUBLIC_WS_URL=           # Bun WS fanout, e.g. wss://ws.robbed.example/v1/ws (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # cloud.walletconnect.com (optional; WC + Robinhood Wallet hidden if unset)
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=        # R2 public CDN base for token images (next/image remote host)
NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD= # ETH notional for posted/finalized disclosure (optional; architect-owned)
