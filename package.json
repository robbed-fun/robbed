{
  "name": "robbed",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "validate": "scripts/validate.sh",
    "e2e": "pnpm --filter @robbed/web exec playwright test",
    "e2e:coverage": "bun scripts/e2e-coverage.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "workerd",
      "bufferutil",
      "utf-8-validate",
      "keccak"
    ]
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "4.4.3",
      "viem": "2.55.0",
      "hono": "4.12.28"
    }
  }
}
