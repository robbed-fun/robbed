{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/deployer.json)",
      "Read(**/keystore/**)"
    ],
    "ask": [
      "Bash(forge script*)"
    ],
    "allow": [
      "Bash(forge build*)",
      "Bash(forge test*)",
      "Bash(forge fmt*)",
      "Bash(forge snapshot*)",
      "Bash(bun test*)",
      "Bash(bun run typecheck*)",
      "Bash(bun run test*)",
      "Bash(bun run validate*)",
      "Bash(bun run e2e:coverage*)",
      "Bash(bun scripts/doc-check.ts*)",
      "Bash(bun scripts/env-sync-check.ts*)",
      "Bash(pnpm install)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-secrets.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-hard-rules.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-solidity.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-typecheck.sh",
            "timeout": 240
          }
        ]
      }
    ]
  }
}
