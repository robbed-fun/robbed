# ROBBED_ API + WS env (docs/developers/runbooks/env-inventory.md §2; api.md §7). Copy to
# .env; no secrets committed. One image, two processes: src/index.ts (Hono HTTP)
# and src/ws.ts (Bun WS fanout). Synced against the inventory by
# scripts/env-sync-check.ts (G-9 env leg) — add rows there BEFORE keys here.

# ── Process / environment ────────────────────────────────────────────────────
API_PORT=3001                # Hono HTTP listen port (default 3001; behind TLS/CDN in prod)
API_ENV=development          # development|test|production — prod enforces DB role split + moderation stub boot-guard
WS_PORT=3002                 # Bun WS fanout listen port (src/ws.ts)

# ── Postgres — role split (api.md §7; REQUIRED in prod, boot refuses otherwise)
DATABASE_URL=                # single-role dev fallback for both legs below (LOCAL ONLY)
DATABASE_URL_RO=             # read-only role on indexer-owned tables (unset in dev ⇒ falls back)
DATABASE_URL_RW=             # read-write role on API-owned moderation_status/audit/impersonation tables only

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379   # subscribe global:*/control:*; moderation queue; rate-limit

# ── Auth / abuse (api.md §6.2, §5) ───────────────────────────────────────────
SESSION_SECRET=              # SECRET — HMAC key for stateless SIWE admin session + CSRF (32B random; insecure dev default in code)
ADMIN_ALLOWLIST=             # comma-separated admin SIWE addresses (OI-A8 — follows Safe signer set O-6)
TRUSTED_PROXY_HEADER=        # header carrying the real client IP behind the CDN (prod: CF-Connecting-IP).
RATE_LIMIT_SCALE=            # multiplies all §6.3 route limits (default 1 = prod; local compose sets 100 for e2e; clamped >=1)
                             # Empty ⇒ socket peer (dev). NEVER the leftmost XFF (rate-limit bypass).

# ── Moderation (api.md §4.3) — gates LISTING visibility only, never chain state
MODERATION_ALLOW_STUBS=true  # permit boot with stub vendors (prod: false unless capped-beta escape, logged)
MODERATION_NSFW_HIDE_THRESHOLD=    # optional — classifier score ≥ this ⇒ auto-hide (default 0.95)
MODERATION_NSFW_REVIEW_THRESHOLD=  # optional — classifier score ≥ this ⇒ review queue (default 0.8)
# MODERATION_CSAM_VENDOR_* / MODERATION_CLASSIFIER_VENDOR_* are reserved (OI-A7,
# not yet read by code) — documented in the inventory as sync:skip; do not set.

# ── Object storage (R2 in prod, minio in dev — Bun.S3Client speaks S3 to both;
#    API-mediated upload write leg, §12.19) ───────────────────────────────────
R2_ENDPOINT=                 # S3 endpoint; R2 form https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com (§12.45); dev: minio endpoint
R2_REGION=auto               # S3 region (default auto)
R2_ACCESS_KEY_ID=            # SECRET — R2/minio write access key
R2_SECRET_ACCESS_KEY=        # SECRET — R2/minio write secret
R2_BUCKET=robbed-assets      # target bucket for images + canonical metadata (§12.45)
R2_PUBLIC_BASE_URL=          # public CDN base; metadata imageUrl MUST start with this (api.md §6.4 SSRF/XSS); dev: minio public URL

# ── Chain reads (cold path only) ─────────────────────────────────────────────
ROBINHOOD_RPC_URL=           # RPC for the cold tokensOwed read on /fees (api.md §3.4) — never in the hot path
TREASURY_ADDRESS=            # optional — treasury Safe → holder `vault` flag (api.md §3.4; O-6)
LP_FEE_VAULT_ADDRESS=        # optional — LPFeeVault → holder `vault` flag (M1 deploy artifact)
CREATOR_VAULT_ADDRESS=       # optional (§12.63/§12.69) — pull-payment CreatorVault; live claimable read + vault fallback. Absent on v1
WETH_ADDRESS=                # optional (§12.69) — chain WETH; classifies a claim's WETH leg for USD (unset ⇒ claimableUsd null, fail-safe §2)

# ── §2.1 large-value confirmation disclosure (§12.47 web-10) ─────────────────
LARGE_VALUE_ETH_THRESHOLD=1.0    # decimal ETH string; mirrors web NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD — config, never a literal

# ── CORS (api.md §6.1; wired 2026-07-12, closes the env-inventory audit gap) ──
# Comma-separated browser origins for the PUBLIC /v1 surface only (admin/internal
# are never opened cross-origin). Production REFUSES TO BOOT when unset; dev
# defaults to http://localhost:4000,http://localhost:3000.
CORS_ALLOWED_ORIGINS=http://localhost:4000

# ── §12.22 search/ranking knobs (formulas-as-config; src/config/ranking.ts) ──
RANK_TICKER_BOOST=1.2            # exact-ticker match boost multiplier
RANK_SIMILARITY_FLOOR=0.25       # pg_trgm similarity floor for search candidates
SEARCH_STATEMENT_TIMEOUT_MS=2000 # per-statement Postgres timeout on the search path (api.md §6)
RANK_TRENDING_HALFLIFE_HOURS=24  # trending sort exponential-decay half-life
