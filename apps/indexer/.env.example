# ROBBED_ indexer env (docs/developers/indexer.md §2). Copy to .env; no secrets committed.
# Startup FAILS CLOSED if a required var is missing/invalid (ponder.config.ts + scripts/migrate.ts).

# ── Chain identity (§12.55 gate) ─────────────────────────────────────────────
INDEXER_CHAIN_ID=            # required, NO default — SELECTS the chain (31337 LOCAL / 46630 TESTNET
                            # / 4663 MAINNET). Must resolve in the shared deployment registry
                            # (packages/shared getDeployment) AND match the live RPC eth_chainId
                            # (double fail-closed). It never DEFINES chain facts — nothing invented
                            # via env. 4663 is refused outside a LOCAL fork stack (registry 4663 is a
                            # fork artifact) unless INDEXER_ALLOW_FORK_4663=1.
INDEXER_ALLOW_FORK_4663=    # optional — set "1" ONLY on the local anvil-fork stack to permit 4663

# ── RPC ──────────────────────────────────────────────────────────────────────
INDEXER_RPC_HTTP=            # required — HTTP RPC (historical backfill + chain-id assert)
INDEXER_RPC_WS=              # optional — Alchemy WS for realtime (<500ms budget, §8)
START_BLOCK=0               # factory deploy block (backfill floor)

# ── Contract addresses (from M1 deploy artifacts; lowercased, non-zero) ──────
CURVE_FACTORY_ADDRESS=       # required — emits TokenCreated; factory anchor for curves+tokens
ROUTER_ADDRESS=              # optional
MIGRATOR_ADDRESS=            # required — V3Migrator, emits Graduated; factory anchor for pools
# V3 factory / NPM default to the ratified registry (spec §12.28, @robbed/shared UNISWAP_V3).
# Override only if the registry moves; must be non-zero.
V3_FACTORY_ADDRESS=
V3_NPM_ADDRESS=
# WETH is NEVER configurable — asserted against the canonical constant (CLAUDE.md).

# ── Curve deploy constants: NO LONGER env ────────────────────────────────────
# Curve immutables (CURVE_SUPPLY, VIRTUAL_ETH_0/VIRTUAL_TOKEN_0, GRADUATION_ETH,
# TRADE_FEE_BPS) are read PER-CURVE from each BondingCurve at TokenCreated via
# viem + @robbed/shared bondingCurveAbi (§12.38/§12.40d). The prior env interim
# (CURVE_SUPPLY_WEI/INITIAL_VIRTUAL_*_WEI/GRADUATION_ETH_WEI) is dropped — do not
# set them; they are ignored.

# ── Off-chain stack ──────────────────────────────────────────────────────────
DATABASE_URL=                # Postgres (pg_trgm asserted); required for migrate/rebuild + sidecars
DATABASE_SCHEMA=             # optional — Ponder schema for the GIN-index migration (default public)
REDIS_URL=                   # pub/sub (used by M2-8 publish path + M2-7 control:reverify)
R2_METADATA_BASE_URL=        # CDN base for canonical metadata JSON (M2-7 verifier); fallback when a
                             # token row carries no metadata_uri — key layout metadata/{keccak-no-0x}.json
METADATA_FETCH_REWRITE_FROM= # split-horizon pair (both or neither, §8.3): browser-visible object-URL
METADATA_FETCH_REWRITE_TO=   # prefix → container-internal minio base (http://minio:9000/...). Set in
                             # EVERY minio-backed compose stack (dev/testnet/mainnet — the public base
                             # is host-mapped localhost, unreachable from the container). Unset only for
                             # a real R2/CDN deploy (reachable everywhere). Fetch-time only; never stored.
ETH_USD_SOURCE_URL=          # HTTP FALLBACK price source for the §3.9 poller — primary on
                             # LOCAL/TESTNET; resilience fallback behind Chainlink on mainnet (§12.51)
# ── §12.51 Chainlink ETH/USD (mainnet-primary branch of the §3.9 poller) ─────
CHAINLINK_ETH_USD_FEED=      # optional — ETH/USD proxy override (recorded default
                             # 0x78F3556b67E17Df817D51Ef5a990cDaF09E8d3A9, §12.51); `off` disables the
                             # branch (required on a fresh local chain launched as id 4663); branch
                             # auto-skips when RPC chain id ≠ 4663. Fail-closed startup asserts:
                             # description()=="ETH / USD", decimals()==8.
ETH_USD_POLL_INTERVAL_MS=    # optional — poller cadence (default 30000; spec band 30–60s, §3.9)
ETH_USD_CHAINLINK_STALENESS_SECONDS= # optional — reject answers with updatedAt older than this ⇒ HTTP
                             # fallback (default 3600 = ETH/USD heartbeat; never a price literal, §2)

# ── Side-processes (M2-6 tracker / M2-7 verifier) ────────────────────────────
TREASURY_ADDRESS=            # optional — Gnosis Safe; sole valid V3 Collect recipient (§6.4/§6.6).
                             # Unset ⇒ gate-7 recipient check degrades to an "unverified" warn.
INDEXER_SIDECARS=            # optional — set to `off` to disable the tracker+verifier loops
PNL_JOB_INTERVAL_MS=         # optional — portfolio PnL job cadence (src/pnl/job.ts; default 60000)

# ── §8.5 bot/farm flow job (M2-13) — ADVISORY labeling only, never gates chain
#    state. Thresholds are spec §8.5 v1 defaults (config, not literals); tune w/
#    M2 data. All optional.
FLOW_JOB_INTERVAL_MS=         # optional — flow-job cadence (default 60000; periodic derive, §4.4)
FLOW_FUNDER_MIN_WALLETS=      # optional — funder fan-out for a cluster (default 20)
FLOW_MICRO_TRANSFER_WEI=      # optional — micro-transfer ceiling wei (default 1e15 = 0.001 ETH)
FLOW_SNIPER_WINDOW_SEC=       # optional — first buy within N s of TokenCreated (default 60)
FLOW_SNIPER_FUNDED_WITHIN_SEC=# optional — funded within N s before that buy (default 3600)
FLOW_MULTIPOOL_EXIT_MIN=      # optional — WETH from ≥N pools in one block (default 3)
FLOW_WASH_FEE_TOLERANCE=      # optional — wash round-trip nets ≤ tol×fee (default 1.5)

# ── Gate-7 metrics (M2-12) — hooks + /metrics endpoint; alert DELIVERY is M4 ──
METRICS_ENABLED=             # optional — set to `off` to not bind the /metrics server
METRICS_PORT=                # optional — gate-7 /metrics port (default 9464)
# Cluster-share alert thresholds from M0 constants.json.governance (§10 gate-7 amend).
CLUSTER_ALERT_PER_TOKEN_PCT= # optional — per-token cluster vol share alert % (default 25)
CLUSTER_ALERT_PLATFORM_PCT=  # optional — platform-wide cluster vol share alert % (default 10)

# ── §8.5.3 hood.fun competitor snapshot (M2-14) — source+timestamped, never a
#    hardcoded metric (§2). Unconfigured ⇒ job writes NOTHING (no fabricated data).
COMPETITOR_SNAPSHOT_INTERVAL_MS= # optional — cadence (default weekly)
