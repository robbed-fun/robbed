{
  "name": "@robbed/indexer",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "ROBBED_ indexer — Ponder → Postgres (+pg_trgm) + Redis pub/sub → Bun WS. M2-4 (config+schema) / M2-5 (handlers + unified trades + candles + rebuild).",
  "scripts": {
    "dev": "ponder dev",
    "start": "ponder start",
    "codegen": "ponder codegen",
    "serve": "ponder serve",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "migrate": "bun run scripts/migrate.ts",
    "rebuild": "bun run scripts/rebuild.ts"
  },
  "dependencies": {
    "@robbed/shared": "workspace:*",
    "ponder": "^0.16.6",
    "hono": "catalog:",
    "viem": "catalog:",
    "pg": "^8.13.1",
    "redis": "6.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.0"
  }
}
