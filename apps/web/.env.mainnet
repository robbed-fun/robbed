# ── ROBBED_ · MAINNET (Robinhood Chain, chain id 4663) ──────────────────────
# Build-time PUBLIC env for the Cloudflare Workers frontend (robbed.fun).
# All NEXT_PUBLIC_* are inlined at `next build` (a runtime Worker var can't
# override an inlined value). No secrets here.
#
# Real data (mock OFF). Point API_BASE_URL / WS_URL at the mainnet Komodo
# backend once it's deployed (they are placeholders until then).
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_RPC_HTTP=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_RPC_WS=wss://feed.mainnet.chain.robinhood.com
NEXT_PUBLIC_API_BASE_URL=https://api.robbed.fun
NEXT_PUBLIC_WS_URL=wss://api.robbed.fun/ws
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-1f7ef06884964a2f82e21cd86e1893b0.r2.dev
NEXT_PUBLIC_MOCK_DATA=false
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=   # set your WalletConnect project id
# NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=1.0

# NOTE: the web currently reads CHAIN_ID as a compile-time constant from
# @robbed/shared (hardcoded 4663). NEXT_PUBLIC_CHAIN_ID above documents the
# intended value; making the app read it (needed for the testnet build) +
# per-env contract-address codegen is the E-3 step of the 3-env plan.
