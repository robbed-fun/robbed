# ── ROBBED_ · MAINNET (Robinhood Chain, chain id 4663) ──────────────────────
# Build-time PUBLIC env for the Cloudflare Workers frontend (robbed.fun).
# All NEXT_PUBLIC_* are inlined at `next build` (a runtime Worker var can't
# override an inlined value). No secrets here.
#
# The connect-wallet flow uses this chain object through wagmi/RainbowKit, so
# robbed.fun must compile with the same mainnet target advertised to wallets.
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_RPC_HTTP=https://rpc.mainnet.chain.robinhood.com
# Public Robinhood mainnet feed is a sequencer feed, not JSON-RPC. Leave unset
# unless a JSON-RPC WS provider is configured.
# NEXT_PUBLIC_RPC_WS=
NEXT_PUBLIC_API_BASE_URL=https://api.robbed.fun
NEXT_PUBLIC_WS_URL=wss://api.robbed.fun/ws
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-1f7ef06884964a2f82e21cd86e1893b0.r2.dev
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=1d38cc7c6d457bf4cf6c0764e2eda788
NEXT_PUBLIC_REQUIRE_WALLETCONNECT=true
# NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=1.0

# RESOLVED 2026-07-12: the web reads NEXT_PUBLIC_CHAIN_ID (validated against
# the shared deployment registry) and derives chain facts + ALL
# addresses from the registry entry. Mainnet builds resolve the 4663 registry
# entry; testnet builds use apps/web/.env.testnet.
