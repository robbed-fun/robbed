{
  "name": "@robbed/web",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "ROBBED_ frontend — Next.js 16 + React 19 App Router on Bun : Discover, Token Detail, Launch + Trust panel. M3-2 design system + M3-3 plumbing.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:coverage": "bun ../../scripts/e2e-coverage.ts",
    "build:cf": "opennextjs-cloudflare build",
    "deploy:cf": "opennextjs-cloudflare deploy",
    "deploy:cf:mainnet": "bash -c 'set -a && . ./.env.mainnet && set +a && opennextjs-cloudflare build && opennextjs-cloudflare deploy'",
    "deploy:cf:testnet": "bash -c 'set -a && . ./.env.testnet && set +a && opennextjs-cloudflare build --config wrangler.testnet.jsonc && opennextjs-cloudflare deploy --config wrangler.testnet.jsonc'",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.9",
    "@rainbow-me/rainbowkit": "2.2.11",
    "@robbed/shared": "workspace:*",
    "@tanstack/react-query": "5.90.3",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lightweight-charts": "5.0.9",
    "lucide-react": "0.545.0",
    "next": "16.2.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.3.1",
    "viem": "catalog:",
    "wagmi": "2.18.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "1.56.0",
    "@tailwindcss/postcss": "4.1.14",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.5",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "jsdom": "26.1.0",
    "tailwindcss": "4.1.14",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.110.0"
  }
}
