# ── ROBBED_ · TESTNET (Robinhood Chain testnet, chain id 46630) ─────────────
# Build-time PUBLIC env for the testnet frontend (testnet.robbed.fun).
# All NEXT_PUBLIC_* are inlined at `next build`. No secrets here.
#
# Real testnet data. API_BASE_URL / WS_URL point at the testnet
# Komodo backend once deployed (placeholders until then).
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_RPC_HTTP=https://rpc.testnet.chain.robinhood.com
NEXT_PUBLIC_RPC_WS=wss://feed.testnet.chain.robinhood.com
NEXT_PUBLIC_API_BASE_URL=https://api.testnet.robbed.fun
NEXT_PUBLIC_WS_URL=wss://api.testnet.robbed.fun/ws
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-1f7ef06884964a2f82e21cd86e1893b0.r2.dev
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=   # set your WalletConnect project id
# NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=1.0

# NOTE: testnet is chain 46630, but the web currently reads CHAIN_ID as a
# compile-time constant from @robbed/shared (hardcoded 4663) + the V3/WETH
# addresses in §12.28 are 4663-mainnet-only. A real testnet build needs the app
# to read NEXT_PUBLIC_CHAIN_ID + per-env contract-address codegen (3-env E-3),
# and testnet V3/WETH addresses pulled from official docs at Phase-T start.
