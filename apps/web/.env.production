# ROBBED_ frontend build-time public env. Next inlines NEXT_PUBLIC_* at build,
# so these MUST be present at `next build` (runtime Worker vars can't override an
# inlined value). All values are PUBLIC (no secrets) — safe to commit.
#
# TEMPORARY: free public Robinhood RPC + placeholder API/WS until the Komodo
# backend is deployed and per-env config (3-env) lands. Update API/WS to the
# real origin then.
NEXT_PUBLIC_RPC_HTTP=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_API_BASE_URL=https://api.robbed.fun
NEXT_PUBLIC_WS_URL=wss://api.robbed.fun/ws
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-1f7ef06884964a2f82e21cd86e1893b0.r2.dev
