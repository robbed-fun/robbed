# apps/web environment template. Copy to.env.local, fill in.
# No secrets here. Values are NEXT_PUBLIC_ (browser-inlined) by design — this
# app holds no server secret; the API owns R2/DB credentials. One exception:
# API_BASE_URL_INTERNAL is server-only (deliberately NOT NEXT_PUBLIC_-prefixed
# so it is never inlined into the client bundle) — still not a secret.

# ── Chain 4663 RPC (src/shared/lib/chain.ts) — from env ONLY, never inlined
NEXT_PUBLIC_RPC_HTTP=
NEXT_PUBLIC_RPC_WS=

# ── Indexer REST + WS (src/shared/api, src/shared/lib/ws.tsx) ────────────────
NEXT_PUBLIC_API_BASE_URL=      # e.g. https://api.robbed.example  (no trailing slash)
NEXT_PUBLIC_WS_URL=            # e.g. wss://ws.robbed.example/v1/ws

# ── Server-only SSR REST base override (split-horizon — web.md) ─────────
# SSR fetches prefer this when set; browsers ALWAYS use NEXT_PUBLIC_API_BASE_URL.
# Leave empty for host-run dev and prod (Workers reach the public API origin);
# compose sets http://api:3001 — inside the web container the host-mapped
# localhost port of NEXT_PUBLIC_API_BASE_URL is unreachable (ECONNREFUSED).
API_BASE_URL_INTERNAL=

# ── WalletConnect (src/shared/lib/wagmi.ts) ──────────────────────────────────
# web-6 NEEDS-USER: obtain a projectId at cloud.walletconnect.com.
# Injected (browser-extension) wallets work in dev WITHOUT this; mobile wallets
# and generic WalletConnect are hidden until it is set.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Set true for production/mainnet builds. Leave false/empty for local dev where
# injected browser wallets are enough.
NEXT_PUBLIC_REQUIRE_WALLETCONNECT=

# ── Token image CDN (next/image remote host) ─────────────────────────────────
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# ── E2E harness (apps/web/e2e — plan I-5a) ───────────────────────────────────
# When "true", the wagmi mock connector (anvil dev accounts) replaces the real
# RainbowKit connectors and window.__ROBBED_E2E__ is mounted. NEVER set in prod.
# NEXT_PUBLIC_* are build-time inlined, so set these on the web server you test.
NEXT_PUBLIC_E2E=
NEXT_PUBLIC_E2E_ACCOUNTS=   # comma-separated anvil addresses: creator,treasury,trader,trader2

# ── Large-value confirmation-disclosure threshold, ETH-denominated ─────
# web-10 / M3-10: architect-owned config value (NOT a literal in code). Rows at
# or above this ETH notional must disclose posted/finalized tiers.
# Value RESOLVED by (2026-07-10) 1.0 ETH (M0/config default,
# retunable in the capped beta).
NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=1.0
