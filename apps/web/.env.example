# apps/web environment template (spec §2/§9). Copy to .env.local, fill in.
# No secrets here. All values are NEXT_PUBLIC_ (browser-visible) by design —
# this app holds no server secret; the API owns R2/DB credentials.

# ── Chain 4663 RPC (src/shared/lib/chain.ts) — from env ONLY, never inlined (§2/§9)
NEXT_PUBLIC_RPC_HTTP=
NEXT_PUBLIC_RPC_WS=

# ── Indexer REST + WS (src/shared/api, src/shared/lib/ws.tsx) ────────────────
NEXT_PUBLIC_API_BASE_URL=      # e.g. https://api.robbed.example  (no trailing slash)
NEXT_PUBLIC_WS_URL=            # e.g. wss://ws.robbed.example/v1/ws

# ── WalletConnect (src/shared/lib/wagmi.ts) ──────────────────────────────────
# web-6 NEEDS-USER: obtain a projectId at cloud.walletconnect.com.
# Injected (browser-extension) wallets work in dev WITHOUT this; WalletConnect +
# Robinhood Wallet (WalletConnect-based) are hidden until it is set.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Token image CDN (next/image remote host) ─────────────────────────────────
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# ── Demo mode (task A) ───────────────────────────────────────────────────────
# When truthy ("true"/"1"/"yes"), the data layer serves src/shared/mock/
# robbed-mock.json instead of hitting the API, for every read the 4 pages render
# (Portfolio renders without a connected wallet). Strictly gated; unset ⇒ live API.
NEXT_PUBLIC_MOCK_DATA=

# ── E2E harness (apps/web/e2e — plan I-5a) ───────────────────────────────────
# When "true", the wagmi mock connector (anvil dev accounts) replaces the real
# RainbowKit connectors and window.__ROBBED_E2E__ is mounted. NEVER set in prod.
# NEXT_PUBLIC_* are build-time inlined, so set these on the web server you test.
NEXT_PUBLIC_E2E=
NEXT_PUBLIC_E2E_ACCOUNTS=   # comma-separated anvil addresses: creator,treasury,trader,trader2

# ── Large-value confirmation-disclosure threshold, ETH-denominated (§2.1) ─────
# web-10 / M3-10: architect-owned config value (NOT a literal in code). Rows at
# or above this ETH notional must disclose posted/finalized tiers. Placeholder
# until the architect furnishes the number (implementation-plan M3-10).
NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=
