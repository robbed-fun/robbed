{
  // Cloudflare Workers config for the ROBBED_ frontend, deployed via OpenNext
  // (@opennextjs/cloudflare). Basis: opennext.js.org/cloudflare/get-started +
  // deploy-komodo-cloudflare.md Part B, verified 2026-07-10.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "robbed",
  "main": ".open-next/worker.js",
  // OpenNext floor is 2024-09-23; a recent date keeps workerd Node APIs current.
  "compatibility_date": "2025-05-05",
  // nodejs_compat: OpenNext's server shim needs Node APIs (Buffer, etc.).
  // global_fetch_strictly_public: OpenNext-required so server fetch() always
  // resolves over the public internet (never worker-internal loopback).
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  // Static assets emitted by `opennextjs-cloudflare build`.
  "assets": { "directory": ".open-next/assets", "binding": "ASSETS" },
  // Preserve any dashboard-set plaintext vars on deploy. Default wrangler
  // behavior treats this file as the source of truth and overrides dashboard
  // vars (developers.cloudflare.com/workers/wrangler/configuration
  // #source-of-truth, verified 2026-07-12); keep_vars keeps them alongside the
  // `vars` below.
  "keep_vars": true,
  "r2_buckets": [
    // Frontend read access to the shared assets bucket (images + canonical
    // metadata). The WRITE path (uploads) stays on the Komodo API (§12.19); the
    // Worker never accepts raw uploads.
    { "binding": "ASSETS_BUCKET", "bucket_name": "robbed-assets" },
    // ISR / `use cache` incremental-cache store (open-next.config.ts →
    // r2IncrementalCache). This override reads the fixed binding name
    // NEXT_INC_CACHE_R2_BUCKET (opennext.js.org/cloudflare/caching); it points at
    // the same bucket, isolated under the default `incremental-cache/` prefix.
    { "binding": "NEXT_INC_CACHE_R2_BUCKET", "bucket_name": "robbed-assets" }
  ],
  // Runtime env for the SERVER side — MUST mirror apps/web/.env.mainnet (the
  // build-time sheet: NEXT_PUBLIC_* are inlined at build; these runtime copies
  // keep SSR process.env in agreement with the inlined values).
  // ⚠ INTERIM TOPOLOGY (2026-07-12): the robbed.fun Worker consumes the
  // mainnet-stack API (api.robbed.fun tunnel), which currently runs the
  // interim TESTNET env (chain 46630, real 46630 contracts). Phase-B swap
  // restores: NEXT_PUBLIC_CHAIN_ID=4663 and
  // NEXT_PUBLIC_RPC_HTTP=https://rpc.mainnet.chain.robinhood.com.
  // API/WS/R2 values survive Phase B unchanged.
  "vars": {
    "NEXT_PUBLIC_CHAIN_ID": "46630",
    "NEXT_PUBLIC_RPC_HTTP": "https://rpc.testnet.chain.robinhood.com",
    "NEXT_PUBLIC_API_BASE_URL": "https://api.robbed.fun",
    "NEXT_PUBLIC_WS_URL": "wss://api.robbed.fun/ws",
    "NEXT_PUBLIC_R2_PUBLIC_BASE_URL": "https://pub-1f7ef06884964a2f82e21cd86e1893b0.r2.dev"
  },
  // Observability: persist Worker logs (incl. auto invocation logs) to the
  // Cloudflare dashboard for debugging. Free-tier compatible. head_sampling_rate
  // 1 = keep 100% while volume is low; lower it if log volume grows.
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
