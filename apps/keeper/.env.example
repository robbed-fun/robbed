# ROBBED_ auto-graduation keeper env (docs/developers/runbooks/keeper.md). Copy to
# .env; NO secrets committed. Startup FAILS CLOSED on a missing/invalid required var
# (src/config.ts) and on a chain-id mismatch vs the live RPC (src/index.ts).

# ── RPC ────────────────────────────────────────────────────────────────────────
# ws(s):// → primary detection is an eth_subscribe push (GraduationReady, <1-2 blocks).
# http(s):// → falls back to log polling; the periodic sweep remains the safety net.
KEEPER_RPC_URL=              # required — chain 4663 (mainnet) / 46630 (testnet) / dev-fork RPC
CHAIN_ID=                    # required — MUST match the live RPC eth_chainId (asserted at boot)

# ── Signer (SECRET — never commit; funded ops wallet, NOT the deployer/treasury) ──
KEEPER_PRIVATE_KEY=          # required — 0x + 64 hex. Fund ~0.05 ETH on testnet; caller reward
                            # (§12.34) offsets each graduate() gas, but the wallet must front it.

# ── Data source for the fallback sweep ───────────────────────────────────────────
DATABASE_URL=                # required — Postgres (read-only use); the sweep reads the indexer's
                            # `tokens` table for ReadyToGraduate-not-yet-graduated curves.
# API_BASE_URL=             # reserved — a future HTTP DbPort alternative to DATABASE_URL (needs a
                            # GET /v1/tokens?status=ready-to-graduate on the API; not wired in v1).

# ── Detection / execution tuning (all optional; safe defaults) ───────────────────
KEEPER_POLL_MS=15000         # fallback-sweep cadence
REDIS_URL=                   # reserved — detection is on-chain (see src/chain.ts DETECTION DECISION);
                            # not required. Compose wires redis for stack consistency only.
KEEPER_GAS_CAP=30000000      # absolute gas ceiling; tx gas = estimate*2 clamped here (NEVER a tight cap)
KEEPER_MAX_ATTEMPTS=3        # send attempts before a persistent-revert (donation-brick) alert
KEEPER_BACKOFF_BASE_MS=500   # backoff base; attempt n waits base*2^(n-1)
KEEPER_FAILED_COOLDOWN_MS=300000  # after a persistent failure, skip the curve this long (no hot-loop)

# ── Balance watch + health ───────────────────────────────────────────────────────
KEEPER_BALANCE_POLL_MS=60000        # wallet-balance refresh cadence
KEEPER_BALANCE_WARN_MULTIPLE=20     # warn when balance < MULTIPLE × (typical graduate cost)
KEEPER_TYPICAL_GRADUATE_GAS=1500000 # §12.62 MIGRATION_GAS_ESTIMATE; sizes the low-balance alert only
KEEPER_PORT=3003                    # GET /healthz (compose healthcheck)
