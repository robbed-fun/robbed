{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "postgres": {
      "command": "uvx",
      "args": ["postgres-mcp", "--access-mode=restricted"],
      "env": {
        "DATABASE_URI": "${ROBBED_DATABASE_URI:-postgresql://robbed:robbed_dev_pw@localhost:4432/robbed}"
      }
    }
  }
}
