# ─────────────────────────────────────────────────────────────────────────────
# ROBBED_ monorepo .gitignore
# Rule of thumb: ignore machine-regenerable build/cache output; COMMIT anything
# that is a source of truth or can't be reproduced. Notable KEEPs (do NOT ignore):
#   - pnpm-lock.yaml            single lockfile, §12.29
#   - contracts/lib/            vendored OpenZeppelin v5 — must be committed
#   - tools/m0/out/             M0 constants: generated from a LIVE ETH/USD fetch,
#                               non-deterministic → the committed values ARE canonical
#   - packages/shared/src/abi/  codegen'd ABIs consumed without a build (§12.38)
#   - **/.env.example           committed templates
#   - apps/indexer/ponder-env.d.ts  Ponder codegen output, committed per Ponder docs
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm/

# ── Secrets / environment (templates stay) ───────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
deployer.json
keystore/

# ── Foundry / Solidity (contracts/lib is vendored → committed) ───────────────
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/.gas-snapshot.tmp

# ── Next.js 16 (apps/web) ────────────────────────────────────────────────────
.next/
apps/web/out/
apps/web/.vercel/
# next-env.d.ts is committed (do not ignore)

# ── OpenNext → Cloudflare Workers (apps/web) ─────────────────────────────────
apps/web/.open-next/
apps/web/.wrangler/
# cloudflare-env.d.ts is generated by `cf-typegen`; keep it out of VCS
apps/web/cloudflare-env.d.ts

# ── Ponder (apps/indexer) — .ponder is cache; ponder-env.d.ts is committed ───
.ponder/
apps/indexer/generated/

# ── TypeScript / build info ──────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Testing / coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# ── Turbo / tool caches ──────────────────────────────────────────────────────
.turbo/
.cache/
.eslintcache

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Docker local volumes (compose uses named volumes; guard bind mounts) ─────
.docker-data/
minio-data/

# ── Claude Code (assets are committed; local overrides are not) ──────────────
.claude/settings.local.json
.claude/**/*.local.json

# ── OS cruft ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors / IDE ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Misc ─────────────────────────────────────────────────────────────────────
*.local
tmp/
.tmp/
tools/localstack/out/
contracts/deployments/4663.json
