#!/usr/bin/env bash
# ROBBED_ commit-msg hook — Conventional Commits header validation.
# Canonical spec: CONTRIBUTING.md §Commit messages. Deterministic, no deps.
#   header:  type(scope)?: subject   — types feat|fix|docs|test|refactor|perf|chore|ci|build;
#            scope optional (lowercase [a-z0-9,/-]); subject starts lowercase-alnum; ≤72 chars.
#   passthrough: Merge…, Revert…, fixup!…, squash!… headers are allowed untouched.

msg_file=$1
header=$(head -n1 "$msg_file")

# Passthrough for git-generated / rebase-workflow headers.
case "$header" in
  Merge\ *|Revert\ *|fixup!*|squash!*) exit 0 ;;
esac

fail() {
  echo "commit-msg: REJECTED header:" >&2
  echo "  $header" >&2
  echo "$1" >&2
  echo "See CONTRIBUTING.md §Commit messages." >&2
  exit 1
}

if ! printf '%s' "$header" | grep -qE '^(feat|fix|docs|test|refactor|perf|chore|ci|build)(\([a-z0-9,/-]+\))?!?: [a-z0-9]'; then
  fail "Expected: type(scope)?: subject — types feat|fix|docs|test|refactor|perf|chore|ci|build; lowercase scope; subject starts with a lowercase letter/digit."
fi

if [ "${#header}" -gt 72 ]; then
  fail "Header is ${#header} chars — must be ≤ 72."
fi

exit 0
