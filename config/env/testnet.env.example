# ROBBED_ testnet compose config. Copy to config/env/testnet.env.
# Never commit the copied file.

# Public deployer address only; signing uses the operator's Foundry wallet.
DEPLOYER_ADDRESS=

TESTNET_CHAIN_ID=46630
TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
TESTNET_RPC_WS_URL=
TESTNET_BLOCKSCOUT_URL=https://explorer.testnet.chain.robinhood.com

TESTNET_PUBLIC_API_BASE_URL=https://api-testnet.robbed.fun
TESTNET_PUBLIC_WS_URL=wss://api-testnet.robbed.fun/ws
TESTNET_PUBLIC_R2_BASE_URL=
TESTNET_CORS_ALLOWED_ORIGINS=https://testnet.robbed.fun,http://localhost:4100

TESTNET_DATABASE_SCHEMA=robbed_testnet_ponder

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=

R2_BUCKET=robbed-assets
