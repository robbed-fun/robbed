# ROBBED_ mainnet compose config. Copy to config/env/mainnet.env.
# Never commit the copied file.

# Contract/Safe deployer. Public address only; signing uses Foundry keystore,
# hardware wallet, browser wallet, KMS, or an unlocked RPC account.
DEPLOYER_ADDRESS=

MAINNET_CHAIN_ID=4663
MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
MAINNET_RPC_WS_URL=

# Do not set MAINNET_INDEXER_CHAIN_ID for a real 4663 deployment.
# It existed only for the old robbed.fun-on-testnet interim stack.
# MAINNET_INDEXER_CHAIN_ID=46630

MAINNET_PUBLIC_API_BASE_URL=https://api.robbed.fun
MAINNET_PUBLIC_WS_URL=wss://api.robbed.fun/ws
# Default for local compose with private MinIO. Set to an R2 public/custom domain
# if you want browsers to read directly from Cloudflare R2.
MAINNET_PUBLIC_R2_BASE_URL=https://api.robbed.fun/v1/assets
MAINNET_CORS_ALLOWED_ORIGINS=https://robbed.fun,http://localhost:4200

MAINNET_DATABASE_SCHEMA=robbed_mainnet_ponder

# Optional indexer observability logs. Empty values keep compose defaults.
INDEXER_EVENT_COUNTS_LOG_MS=
INDEXER_PONDER_RAW_LOG_BLOCKS=
INDEXER_PONDER_RAW_LOG_MAX_ROWS=

POSTGRES_USER=robbed
POSTGRES_PASSWORD=
POSTGRES_DB=robbed

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=robbed-assets

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_LARGE_VALUE_ETH_THRESHOLD=
